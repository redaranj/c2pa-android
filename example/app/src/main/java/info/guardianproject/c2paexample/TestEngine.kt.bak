            steps.add(if (ingredient != null) "✓ Ingredient data found" else "✓ No ingredient data (expected for some images)")
            
            TestResult(
                name = "Read Ingredient",
                success = true,
                message = steps.joinToString("\n"),
                details = ingredient?.take(200)
            )
        } catch (e: Exception) {
            steps.add("✗ Failed to read ingredient: ${e.message}")
            TestResult(
                name = "Read Ingredient",
                success = false,
                message = steps.joinToString("\n"),
                details = e.toString()
            )
        } finally {
            testImageFile.delete()
        }
    }
    
