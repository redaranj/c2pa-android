                )
            } catch (e: C2PAError) {
                steps.add("✓ Correctly threw C2PAError for invalid file")
                steps.add("✓ Error: ${e.message}")
                TestResult(
                    name = "Invalid File Handling",
                    success = true,
                    message = steps.joinToString("\n"),
                    details = null
                )
            }
        } finally {
            tempFile.delete()
        }
    }
    
    private suspend fun testResourceReading(): TestResult {
        val steps = mutableListOf<String>()
        
        return try {
            val imageData = getResourceAsBytes(R.raw.adobe_20220124_ci)
            val stream = MemoryC2PAStream(imageData)
            val reader = C2PAReader.fromStream("image/jpeg", stream)
            
            steps.add("✓ Created reader from test image")
            
            // Get manifest to find resource URIs
            val manifestJSON = reader.json()
            val manifest = JSONObject(manifestJSON)
            
            // Try to find a thumbnail or other resource
            var resourceFound = false
            if (manifest.has("manifests")) {
                val manifests = manifest.getJSONObject("manifests")
                val keys = manifests.keys()
                while (keys.hasNext() && !resourceFound) {
                    val key = keys.next()
                    val m = manifests.getJSONObject(key)
                    if (m.has("thumbnail")) {
                        val thumbnail = m.getJSONObject("thumbnail")
                        if (thumbnail.has("identifier")) {
                            val uri = thumbnail.getString("identifier")
                            steps.add("✓ Found thumbnail resource: $uri")
                            
                            val resourceStream = MemoryC2PAStream()
                            try {
                                reader.resource(uri, resourceStream)
                                val resourceData = resourceStream.getData()
                                steps.add("✓ Successfully read resource (${resourceData.size} bytes)")
                                resourceFound = true
                            } catch (e: Exception) {
                                steps.add("✗ Failed to read resource: ${e.message}")
                            } finally {
                                resourceStream.close()
                            }
                        }
                    }
                }
            }
            
            if (!resourceFound) {
                steps.add("✓ No resources found in manifest (this is OK)")
            }
            
            reader.close()
            stream.close()
            
            TestResult(
                name = "Resource Reading",
                success = true,
                message = steps.joinToString("\n"),
                details = null
            )
        } catch (e: Exception) {
            steps.add("✗ Failed: ${e.message}")
            TestResult(
                name = "Resource Reading",
                success = false,
                message = steps.joinToString("\n"),
                details = e.toString()
            )
        }
    }
    
