                            message = testSteps.joinToString("\n"),
                            details = e.toString()
                        )
                    } finally {
                        destStream.close()
                    }
                } finally {
                    reader.close()
                }
            } finally {
                stream.close()
            }
        } catch (e: Exception) {
            testSteps.add("✗ Failed reader resource error handling test: ${e.message}")
            return TestResult(
                name = "Reader Resource Error Handling",
                success = false,
                message = testSteps.joinToString("\n"),
                details = e.toString()
            )
        }
    }
    
    // MARK: - Hardware Security Tests (StrongBox/TEE equivalent to iOS Secure Enclave)
    
    private fun testHardwareSecurityCapabilities(context: Context): TestResult {
        val testSteps = mutableListOf<String>()
        
        try {
            val capabilities = C2PA.getHardwareSecurityCapabilities(context)
            testSteps.add("✓ Retrieved device security capabilities")
            
            testSteps.add("Hardware Security: ${if (capabilities.hasSecureHardware) "Available" else "Not Available"}")
            testSteps.add("StrongBox Support: ${if (capabilities.hasStrongBox) "Available" else "Not Available"}")
            testSteps.add("Biometric Support: ${if (capabilities.hasBiometrics) "Available" else "Not Available"}")
            testSteps.add("Keyguard Security: ${if (capabilities.hasKeyguard) "Enabled" else "Disabled"}")
            testSteps.add("Android Version: ${capabilities.androidVersion}")
            testSteps.add("Security Patch: ${capabilities.securityPatchLevel}")
            
            val hasMinimumSecurity = capabilities.hasSecureHardware && capabilities.hasKeyguard
            
            if (hasMinimumSecurity) {
                testSteps.add("✓ Device meets minimum hardware security requirements")
            } else {
                testSteps.add("✗ Device lacks minimum hardware security requirements")
            }
            
            return TestResult(
                name = "Hardware Security Capabilities",
                success = hasMinimumSecurity,
                message = testSteps.joinToString("\n"),
                details = """
                    StrongBox: ${capabilities.hasStrongBox}
                    TEE: ${capabilities.hasSecureHardware && !capabilities.hasStrongBox}
                    Biometrics: ${capabilities.hasBiometrics}
                    Android Version: ${capabilities.androidVersion}
                    Security Patch: ${capabilities.securityPatchLevel}
                """.trimIndent()
            )
        } catch (e: Exception) {
            testSteps.add("✗ Failed to get security capabilities: ${e.message}")
            return TestResult(
                name = "Hardware Security Capabilities",
                success = false,
                message = testSteps.joinToString("\n"),
                details = e.toString()
            )
        }
    }
    
    private fun testHardwareKeyGeneration(): TestResult {
        val testSteps = mutableListOf<String>()
        val keyAlias = "c2pa_test_hardware_key_${System.currentTimeMillis()}"
        
        try {
            if (android.os.Build.VERSION.SDK_INT < android.os.Build.VERSION_CODES.M) {
                testSteps.add("✓ Hardware keys require Android 6.0+, current version not supported")
                return TestResult(
                    name = "Hardware Key Generation",
                    success = true,
                    message = testSteps.joinToString("\n"),
                    details = "Android version ${android.os.Build.VERSION.SDK_INT} < 23 (Android 6.0)"
                )
            }
            
            testSteps.add("✓ Android version supports hardware keys")
            
            // Test StrongBox key generation
            try {
                val strongBoxKey = C2PA.generateHardwareKey(
                    keyAlias = "${keyAlias}_strongbox",
                    requireStrongBox = true,
                    requireBiometric = false // Disable biometric for testing
                )
                testSteps.add("✓ Generated StrongBox-backed key successfully")
                testSteps.add("✓ StrongBox attestation: ${strongBoxKey.attestation.hasStrongBox}")
                
                // Clean up
                C2PA.deleteHardwareKey("${keyAlias}_strongbox")
                testSteps.add("✓ Cleaned up StrongBox test key")
            } catch (e: Exception) {
                testSteps.add("✗ StrongBox key generation failed: ${e.message}")
                
                // Try TEE fallback
                try {
                    val teeKey = C2PA.generateHardwareKey(
                        keyAlias = "${keyAlias}_tee",
                        requireStrongBox = false,
                        requireBiometric = false
                    )
                    testSteps.add("✓ Generated TEE-backed key as fallback")
                    testSteps.add("✓ TEE attestation: ${teeKey.attestation.isHardwareBacked}")
                    
                    // Clean up
                    C2PA.deleteHardwareKey("${keyAlias}_tee")
                    testSteps.add("✓ Cleaned up TEE test key")
                } catch (e2: Exception) {
                    testSteps.add("✗ TEE key generation also failed: ${e2.message}")
                    return TestResult(
                        name = "Hardware Key Generation",
                        success = false,
                        message = testSteps.joinToString("\n"),
                        details = "Both StrongBox and TEE failed: $e, $e2"
                    )
                }
            }
            
            return TestResult(
                name = "Hardware Key Generation",
                success = true,
                message = testSteps.joinToString("\n"),
                details = "Successfully generated and tested hardware-backed keys"
            )
        } catch (e: Exception) {
            testSteps.add("✗ Hardware key generation test failed: ${e.message}")
            return TestResult(
                name = "Hardware Key Generation",
                success = false,
                message = testSteps.joinToString("\n"),
                details = e.toString()
            )
        }
    }
    
    private fun testHardwareBackedSignerCreation(context: Context): TestResult {
        val testSteps = mutableListOf<String>()
        val keyAlias = "c2pa_test_signer_${System.currentTimeMillis()}"
        
        try {
            if (android.os.Build.VERSION.SDK_INT < android.os.Build.VERSION_CODES.M) {
                testSteps.add("✓ Hardware signers require Android 6.0+, current version not supported")
                return TestResult(
                    name = "Hardware-Backed Signer Creation",
                    success = true,
                    message = testSteps.joinToString("\n"),
                    details = "Android version ${android.os.Build.VERSION.SDK_INT} < 23 (Android 6.0)"
                )
            }
            
            // Get test certificate
            val certPem = getResourceAsString(context, R.raw.es256_certs)
            testSteps.add("✓ Loaded test certificate")
            
            try {
                val signer = C2PA.createHardwareBackedSigner(
                    keyAlias = keyAlias,
                    certificateChain = certPem,
                    algorithm = "es256",
                    requireStrongBox = false, // Try TEE first for broader compatibility
                    requireBiometric = false  // Disable biometric for testing
                )
                
                testSteps.add("✓ Created hardware-backed signer successfully")
                
                try {
                    val reserveSize = signer.reserveSize()
                    testSteps.add("✓ Signer reserve size: $reserveSize bytes")
                    
                    if (reserveSize > 0) {
                        testSteps.add("✓ Hardware signer is functional")
                    } else {
                        testSteps.add("✗ Invalid reserve size from hardware signer")
                    }
                    
                    signer.close()
                    testSteps.add("✓ Closed hardware signer")
                } catch (e: Exception) {
                    signer.close()
                    throw e
                }
                
                // Clean up
                C2PA.deleteHardwareKey(keyAlias)
                testSteps.add("✓ Cleaned up test key")
                
                return TestResult(
                    name = "Hardware-Backed Signer Creation",
                    success = true,
                    message = testSteps.joinToString("\n"),
                    details = "Successfully created and tested hardware-backed C2PA signer"
                )
            } catch (e: Exception) {
                // Clean up on failure
                C2PA.deleteHardwareKey(keyAlias)
                throw e
            }
        } catch (e: Exception) {
            testSteps.add("✗ Hardware-backed signer creation failed: ${e.message}")
            return TestResult(
                name = "Hardware-Backed Signer Creation",
                success = false,
                message = testSteps.joinToString("\n"),
                details = e.toString()
            )
        }
    }
    
    private fun testHardwareKeyAttestation(): TestResult {
        val testSteps = mutableListOf<String>()
        val keyAlias = "c2pa_test_attestation_${System.currentTimeMillis()}"
        
        try {
            if (android.os.Build.VERSION.SDK_INT < android.os.Build.VERSION_CODES.M) {
                testSteps.add("✓ Key attestation requires Android 6.0+, current version not supported")
                return TestResult(
                    name = "Hardware Key Attestation",
                    success = true,
                    message = testSteps.joinToString("\n"),
                    details = "Android version ${android.os.Build.VERSION.SDK_INT} < 23 (Android 6.0)"
                )
            }
            
            try {
                val generatedKey = C2PA.generateHardwareKey(
                    keyAlias = keyAlias,
                    requireStrongBox = false,
                    requireBiometric = false
                )
                testSteps.add("✓ Generated hardware key for attestation testing")
                
                val attestation = C2PA.getKeyAttestation(keyAlias)
                testSteps.add("✓ Retrieved key attestation")
                
                testSteps.add("Hardware-backed: ${attestation.isHardwareBacked}")
                testSteps.add("Security level: ${attestation.securityLevel}")
                testSteps.add("StrongBox: ${attestation.hasStrongBox}")
                testSteps.add("Attestation chain length: ${attestation.attestationChain?.size ?: 0}")
                
                val success = attestation.isHardwareBacked
                
                if (success) {
                    testSteps.add("✓ Key is properly hardware-backed")
                    
                    when (attestation.securityLevel) {
                        HardwareSecurity.SecurityLevel.STRONGBOX_BACKED -> {
                            testSteps.add("✓ StrongBox security level (highest)")
                        }
                        HardwareSecurity.SecurityLevel.TEE_BACKED -> {
                            testSteps.add("✓ TEE security level (secure)")
                        }
                        HardwareSecurity.SecurityLevel.SOFTWARE_ONLY -> {
                            testSteps.add("✗ Software-only security level")
                        }
                    }
                } else {
                    testSteps.add("✗ Key is not hardware-backed")
                }
                
                // Clean up
                C2PA.deleteHardwareKey(keyAlias)
                testSteps.add("✓ Cleaned up attestation test key")
                
                return TestResult(
                    name = "Hardware Key Attestation",
                    success = success,
                    message = testSteps.joinToString("\n"),
                    details = """
                        Hardware-backed: ${attestation.isHardwareBacked}
                        Security level: ${attestation.securityLevel}
                        StrongBox: ${attestation.hasStrongBox}
                        Attestation chain: ${attestation.attestationChain?.size ?: 0} certificates
                    """.trimIndent()
                )
            } catch (e: Exception) {
                // Clean up on failure
                C2PA.deleteHardwareKey(keyAlias)
                throw e
            }
        } catch (e: Exception) {
            testSteps.add("✗ Hardware key attestation test failed: ${e.message}")
            return TestResult(
                name = "Hardware Key Attestation",
                success = false,
                message = testSteps.joinToString("\n"),
                details = e.toString()
            )
        }
    }
    
    private fun testStrongBoxTEEDetection(context: Context): TestResult {
        val testSteps = mutableListOf<String>()
        
        try {
            val capabilities = C2PA.getHardwareSecurityCapabilities(context)
            testSteps.add("✓ Retrieved device capabilities")
            
            when {
                capabilities.hasStrongBox -> {
                    testSteps.add("✓ Device has StrongBox support (highest security)")
                    testSteps.add("  This is equivalent to iOS Secure Enclave")
                    
                    // Test StrongBox key generation
                    val keyAlias = "c2pa_strongbox_test_${System.currentTimeMillis()}"
                    
                    if (android.os.Build.VERSION.SDK_INT >= android.os.Build.VERSION_CODES.M) {
                        try {
                            val strongBoxKey = C2PA.generateHardwareKey(
                                keyAlias = keyAlias,
                                requireStrongBox = true,
                                requireBiometric = false
                            )
                            
                            if (strongBoxKey.attestation.hasStrongBox) {
                                testSteps.add("✓ Successfully created StrongBox key")
                                testSteps.add("✓ StrongBox attestation confirmed")
                            } else {
                                testSteps.add("✗ Key created but not in StrongBox")
                            }
                            
                            C2PA.deleteHardwareKey(keyAlias)
                        } catch (e: Exception) {
                            testSteps.add("✗ StrongBox key creation failed: ${e.message}")
                        }
                    }
                }
                capabilities.hasSecureHardware -> {
                    testSteps.add("✓ Device has TEE support (secure)")
                    testSteps.add("  This provides hardware-backed security")
                    testSteps.add("  Similar to iOS Secure Enclave but not dedicated chip")
                }
                else -> {
                    testSteps.add("✗ Device has no hardware security support")
                    testSteps.add("  Keys will be software-only")
                }
            }
            
            val securityLevel = when {
                capabilities.hasStrongBox -> "StrongBox (Dedicated Chip)"
                capabilities.hasSecureHardware -> "TEE (Trusted Execution Environment)"
                else -> "Software Only"
            }
            
            testSteps.add("Security Level: $securityLevel")
            
            return TestResult(
                name = "StrongBox vs TEE Detection",
                success = capabilities.hasSecureHardware,
                message = testSteps.joinToString("\n"),
                details = """
                    StrongBox Available: ${capabilities.hasStrongBox}
                    TEE Available: ${capabilities.hasSecureHardware}
                    Security Level: $securityLevel
                    Android Version: ${capabilities.androidVersion}
                """.trimIndent()
            )
        } catch (e: Exception) {
            testSteps.add("✗ StrongBox/TEE detection failed: ${e.message}")
            return TestResult(
                name = "StrongBox vs TEE Detection",
                success = false,
                message = testSteps.joinToString("\n"),
                details = e.toString()
            )
        }
    }
    
    private fun testHardwareKeyLifecycle(): TestResult {
        val testSteps = mutableListOf<String>()
        val keyAlias = "c2pa_lifecycle_test_${System.currentTimeMillis()}"
        
        try {
            if (android.os.Build.VERSION.SDK_INT < android.os.Build.VERSION_CODES.M) {
                testSteps.add("✓ Hardware key lifecycle requires Android 6.0+, current version not supported")
                return TestResult(
                    name = "Hardware Key Lifecycle",
                    success = true,
                    message = testSteps.joinToString("\n"),
                    details = "Android version ${android.os.Build.VERSION.SDK_INT} < 23 (Android 6.0)"
                )
            }
            
            // Test key creation
            val generatedKey = C2PA.generateHardwareKey(
                keyAlias = keyAlias,
                requireStrongBox = false,
                requireBiometric = false
            )
            testSteps.add("✓ Created hardware key")
            
            // Test key existence
            val attestation1 = C2PA.getKeyAttestation(keyAlias)
            if (attestation1.isHardwareBacked) {
                testSteps.add("✓ Key confirmed as hardware-backed")
            } else {
                testSteps.add("✗ Key not hardware-backed")
            }
            
            // Test public key export
            val publicKeyPEM = C2PA.exportHardwarePublicKey(keyAlias)
            if (publicKeyPEM != null && publicKeyPEM.contains("BEGIN PUBLIC KEY")) {
                testSteps.add("✓ Successfully exported public key")
            } else {
                testSteps.add("✗ Failed to export public key")
            }
            
            // Test key usage (attestation retrieval)
            val attestation2 = C2PA.getKeyAttestation(keyAlias)
            if (attestation2.keyInfo != null) {
                testSteps.add("✓ Key info accessible")
                testSteps.add("  Key algorithm: ${attestation2.keyInfo?.algorithm ?: "unknown"}")
                testSteps.add("  Key size: ${attestation2.keyInfo?.keySize ?: "unknown"}")
            } else {
                testSteps.add("✗ Key info not accessible")
            }
            
            // Test key deletion
            val deleted = C2PA.deleteHardwareKey(keyAlias)
            if (deleted) {
                testSteps.add("✓ Successfully deleted hardware key")
            } else {
                testSteps.add("✗ Failed to delete hardware key")
            }
            
            // Verify key is gone
            val attestation3 = C2PA.getKeyAttestation(keyAlias)
            if (!attestation3.isHardwareBacked && attestation3.keyInfo == null) {
                testSteps.add("✓ Key confirmed deleted")
            } else {
                testSteps.add("✗ Key still exists after deletion")
            }
            
            val success = attestation1.isHardwareBacked && deleted
            
            return TestResult(
                name = "Hardware Key Lifecycle",
                success = success,
                message = testSteps.joinToString("\n"),
                details = """
                    Key created: ${generatedKey.keyPair != null}
                    Hardware-backed: ${attestation1.isHardwareBacked}
                    Public key exported: ${publicKeyPEM != null}
                    Key deleted: $deleted
                    Security level: ${attestation1.securityLevel}
                """.trimIndent()
            )
        } catch (e: Exception) {
            // Clean up on failure
            try {
                C2PA.deleteHardwareKey(keyAlias)
            } catch (cleanupException: Exception) {
                // Ignore cleanup errors
            }
            
            testSteps.add("✗ Hardware key lifecycle test failed: ${e.message}")
            return TestResult(
                name = "Hardware Key Lifecycle",
                success = false,
                message = testSteps.joinToString("\n"),
                details = e.toString()
            )
        }
    }
    
    // Helper functions
    
    private fun getResourceAsBytes(context: Context, resourceId: Int): ByteArray {
        val inputStream = context.resources.openRawResource(resourceId)
        val data = inputStream.readBytes()
        inputStream.close()
        return data
    }
    
    private fun getResourceAsString(context: Context, resourceId: Int): String {
        val inputStream = context.resources.openRawResource(resourceId)
        val text = inputStream.bufferedReader().use { it.readText() }
        inputStream.close()
        return text
    }
    
    private fun copyResourceToFile(context: Context, resourceId: Int, fileName: String): File {
        val file = File(context.cacheDir, fileName)
        val inputStream = context.resources.openRawResource(resourceId)
        file.outputStream().use { output ->
            inputStream.copyTo(output)
        }
        inputStream.close()
        return file
    }
    
    private fun createSimpleJPEGThumbnail(): ByteArray {
        return byteArrayOf(
            0xFF.toByte(), 0xD8.toByte(), // JPEG SOI
            0xFF.toByte(), 0xE0.toByte(), // JFIF APP0
            0x00, 0x10, // Length
            0x4A, 0x46, 0x49, 0x46, // "JFIF"
            0x00, 0x01, // Version
            0x01, 0x01, // Units
            0x00, 0x48, // X density
            0x00, 0x48, // Y density
            0x00, 0x00, // Thumbnail size
            0xFF.toByte(), 0xD9.toByte() // JPEG EOI
        )
    }
}