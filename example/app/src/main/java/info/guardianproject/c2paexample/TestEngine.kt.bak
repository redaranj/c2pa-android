            val port = server.start()
            steps.add("✓ Started test signing server on port $port")
            
            // Small delay to ensure server is ready
            delay(100)
            
            val url = "http://localhost:$port/sign"
            
            // Create web service signer
            val signer = C2PASigner.fromWebService(
                SigningAlgorithm.ES256,
                certificate,
                null,
                WebServiceHelpers.basicPOSTRequestBuilder(url)
            )
            steps.add("✓ Created web service signer")
            
            // Test signing with builder
            val manifestJSON = """
            {
                "claim_generator": "test_app/1.0",
                "assertions": []
            }
            """.trimIndent()
            
            val builder = C2PABuilder.fromJson(manifestJSON)
            val imageData = getResourceAsBytes(R.raw.pexels_asadphoto_457882)
            val sourceStream = MemoryC2PAStream(imageData)
            val destStream = MemoryC2PAStream()
            
            val manifestBytes = builder.sign("image/jpeg", sourceStream, destStream, signer)
            val signedData = destStream.getData()
            
            steps.add("✓ Successfully signed image using web service")
            steps.add("✓ Original size: ${imageData.size}, Signed size: ${signedData.size}")
            
            // Cleanup
            server.stop()
            builder.close()
            signer.close()
            sourceStream.close()
            destStream.close()
            
