    private suspend fun testWebServiceSignerCreation(context: Context): TestResult {
        val testSteps = mutableListOf<String>()
        var server: SimpleSigningServer? = null
        
        return try {
            val (signingServer, certificate) = SimpleSigningServer.createTestSigningServer(context)
            server = signingServer
            testSteps.add("✓ Created C2PA signer from bundle keys")
            
            val port = server.start()
            testSteps.add("✓ Started HTTP signing server on port $port")
            
            delay(100) // 0.1 seconds
            
            val webServiceSigner = C2PASigner.fromWebService(
                "es256",
                certificate,
                "http://127.0.0.1:$port/sign"
            ) ?: throw C2PAError.Api("Failed to create web service signer")
            
            testSteps.add("✓ Created web service signer successfully")
            
            try {
                val testImageData = getResourceAsBytes(context, R.raw.adobe_20220124_ci)
                
                val manifestJSON = """
                    {
                        "claim_generator": "c2pa-android-web-service-test/1.0.0",
                        "claim_generator_info": [
                            {
                                "name": "c2pa-android-web-service-test",
                                "version": "1.0.0"
                            }
                        ],
                        "title": "Web Service Real Signing Test",
                        "assertions": [
                            {
                                "label": "c2pa.test",
                                "data": {
                                    "test": true,
                                    "signed_with": "web_service"
                                }
                            }
                        ]
                    }
                """.trimIndent()
                
                val builder = C2PABuilder.fromJson(manifestJSON)
                    ?: throw C2PAError.Api("Failed to create builder")
                
                try {
                    val sourceStream = MemoryC2PAStream(testImageData)
                    val destStream = MemoryC2PAStream()
                    
                    try {
                        val result = builder.sign("image/jpeg", sourceStream, destStream, webServiceSigner)
                        val success = result.size > testImageData.size
                        
                        if (success) {
                            testSteps.add("✓ Successfully signed image using web service")
                            testSteps.add("✓ Signed image size: ${result.size} bytes (original: ${testImageData.size})")
                            
                            // Verify the signed image
                            destStream.seek(0, SeekMode.START.value)
                            val reader = C2PAReader.fromStream("image/jpeg", destStream)
                            
                            val verificationSuccess = reader != null
                            if (verificationSuccess) {
                                val manifest = reader!!.toJson()
                                val hasExpectedContent = manifest.contains("web_service")
                                testSteps.add("✓ Verified signed image contains expected manifest content")
                                reader.close()
                            } else {
                                testSteps.add("✗ Failed to verify signed image")
                            }
                        } else {
                            testSteps.add("✗ Web service signing failed or produced invalid result")
                        }
                        
                        TestResult(
                            name = "Web Service Real Signing & Verification",
                            success = success,
                            message = testSteps.joinToString("\n"),
                            details = """
                                Server port: $port
                                Original size: ${testImageData.size} bytes
                                Signed size: ${result.size} bytes
                            """.trimIndent()
                        )
                    } finally {
                        sourceStream.close()
                        destStream.close()
                    }
                } finally {
                    builder.close()
                }
            } finally {
                webServiceSigner.close()
            }
        } catch (e: Exception) {
            testSteps.add("✗ Failed web service signer test: ${e.message}")
            TestResult(
                name = "Web Service Real Signing & Verification",
                success = false,
                message = testSteps.joinToString("\n"),
                details = e.toString()
            )
        } finally {
            server?.stop()
        }
    }
    
