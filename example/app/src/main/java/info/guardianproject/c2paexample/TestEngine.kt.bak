    private suspend fun testWriteOnlyStreams(): TestResult {
        val steps = mutableListOf<String>()
        
        return try {
            // Create a write-only stream
            val stream = object : C2PAStream() {
                private val buffer = mutableListOf<Byte>()
                
                override fun read(buffer: ByteArray, length: Long): Long = -1L // Not supported
                
                override fun seek(offset: Long, mode: Int): Long = buffer.size.toLong()
                
                override fun write(data: ByteArray, length: Long): Long {
                    val bytesToWrite = minOf(length.toInt(), data.size)
                    for (i in 0 until bytesToWrite) {
                        buffer.add(data[i])
                    }
                    return bytesToWrite.toLong()
                }
                
                override fun flush(): Long = 0L
            }
            
            steps.add("✓ Created write-only stream")
            
            // Test writing
            val testData = "Hello, World!".toByteArray()
            val written = stream.write(testData, testData.size.toLong())
            steps.add("✓ Wrote ${written} bytes to stream")
            
            stream.close()
            
            TestResult(
                name = "Write-Only Streams",
                success = written == testData.size.toLong(),
                message = steps.joinToString("\n"),
                details = null
            )
        } catch (e: Exception) {
            steps.add("✗ Failed: ${e.message}")
            TestResult(
                name = "Write-Only Streams",
                success = false,
                message = steps.joinToString("\n"),
                details = e.toString()
            )
        }
    }
    
    private suspend fun testCustomStreamCallbacks(): TestResult {
        val steps = mutableListOf<String>()
        
        return try {
            var readCount = 0
            var seekCount = 0
            var writeCount = 0
            var flushCount = 0
            
            val stream = object : C2PAStream() {
                private val data = ByteArray(1024)
                private var position = 0
                
                override fun read(buffer: ByteArray, length: Long): Long {
                    readCount++
                    val toRead = minOf(length.toInt(), data.size - position, buffer.size)
                    if (toRead <= 0) return 0L
                    System.arraycopy(data, position, buffer, 0, toRead)
                    position += toRead
                    return toRead.toLong()
                }
                
                override fun seek(offset: Long, mode: Int): Long {
                    seekCount++
                    position = when (mode) {
                        SeekMode.START.value -> offset.toInt()
                        SeekMode.CURRENT.value -> position + offset.toInt()
                        SeekMode.END.value -> data.size + offset.toInt()
                        else -> return -1L
                    }
                    if (position < 0) position = 0
                    if (position > data.size) position = data.size
                    return position.toLong()
                }
                
                override fun write(writeData: ByteArray, length: Long): Long {
                    writeCount++
                    val toWrite = minOf(length.toInt(), writeData.size, data.size - position)
                    if (toWrite <= 0) return 0L
                    System.arraycopy(writeData, 0, data, position, toWrite)
                    position += toWrite
                    return toWrite.toLong()
                }
                
                override fun flush(): Long {
                    flushCount++
                    return 0L
                }
            }
            
            steps.add("✓ Created custom stream with tracking")
            
            // Test operations
            val testData = "Test".toByteArray()
            stream.write(testData, testData.size.toLong())
            stream.seek(0, SeekMode.START.value)
            val readBuffer = ByteArray(10)
            stream.read(readBuffer, 4)
            stream.flush()
            
            steps.add("✓ Read calls: $readCount")
            steps.add("✓ Seek calls: $seekCount")
            steps.add("✓ Write calls: $writeCount")
            steps.add("✓ Flush calls: $flushCount")
            
            stream.close()
            
            TestResult(
                name = "Custom Stream Callbacks",
                success = readCount > 0 && seekCount > 0 && writeCount > 0 && flushCount > 0,
                message = steps.joinToString("\n"),
                details = null
            )
        } catch (e: Exception) {
            steps.add("✗ Failed: ${e.message}")
            TestResult(
                name = "Custom Stream Callbacks",
                success = false,
                message = steps.joinToString("\n"),
                details = e.toString()
            )
        }
    }
    
