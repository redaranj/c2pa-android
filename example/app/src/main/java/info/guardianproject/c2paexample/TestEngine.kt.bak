    private suspend fun testBuilderFromArchive(): TestResult {
        val steps = mutableListOf<String>()
        
        return try {
            // First create an archive
            val manifestJSON = """
            {
                "claim_generator": "test_app/1.0",
                "assertions": []
            }
            """.trimIndent()
            
            val builder1 = C2PABuilder.fromJson(manifestJSON)
            builder1.setNoEmbed()
            
            val archiveStream = MemoryC2PAStream()
            builder1.writeArchive(archiveStream)
            builder1.close()
            
            steps.add("✓ Created test archive")
            
            // Now create builder from archive
            archiveStream.seek(0, SeekMode.START.value)
            val builder2 = C2PABuilder.fromArchive(archiveStream)
            steps.add("✓ Created Builder from archive successfully")
            
            builder2.close()
            archiveStream.close()
            
            TestResult(
                name = "Builder from Archive",
                success = true,
                message = steps.joinToString("\n"),
                details = null
            )
        } catch (e: Exception) {
            steps.add("✗ Failed: ${e.message}")
            TestResult(
                name = "Builder from Archive",
                success = false,
                message = steps.joinToString("\n"),
                details = e.toString()
            )
        }
    }
    
    private suspend fun testReaderWithManifestData(): TestResult {
        val steps = mutableListOf<String>()
        
        return try {
            // Get a signed image with manifest
            val imageData = getResourceAsBytes(R.raw.adobe_20220124_ci)
            val stream1 = MemoryC2PAStream(imageData)
            val reader1 = C2PAReader.fromStream("image/jpeg", stream1)
            val manifestJSON = reader1.json()
            val manifestData = manifestJSON.toByteArray()
            reader1.close()
            stream1.close()
            
            steps.add("✓ Extracted manifest data from signed image")
            
            // Create reader with manifest data
            val stream2 = MemoryC2PAStream(imageData)
            val reader2 = C2PAReader.fromManifestDataAndStream("image/jpeg", stream2, manifestData)
            steps.add("✓ Created Reader with manifest data successfully")
            
            val json2 = reader2.json()
            steps.add("✓ Read JSON from reader with manifest data")
            
            reader2.close()
            stream2.close()
            
            TestResult(
                name = "Reader with Manifest Data",
                success = true,
                message = steps.joinToString("\n"),
                details = null
            )
        } catch (e: Exception) {
            steps.add("✗ Failed: ${e.message}")
            TestResult(
                name = "Reader with Manifest Data",
                success = false,
                message = steps.joinToString("\n"),
                details = e.toString()
            )
        }
    }
    
    private suspend fun testSignerWithCallback(): TestResult {
        val steps = mutableListOf<String>()
        
        return try {
