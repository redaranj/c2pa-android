package info.guardianproject.c2paexample

import android.content.Context
import info.guardianproject.c2pa.*
import kotlinx.coroutines.*
import org.json.JSONObject
import java.io.File
import java.security.SecureRandom
import java.util.*

data class TestResult(
    val id: String = UUID.randomUUID().toString(),
    val name: String,
    val success: Boolean,
    val message: String,
    val details: String? = null
)

/**
 * Test engine that matches the iOS TestEngine functionality
 * Provides comprehensive testing of the C2PA library
 */
class TestEngine private constructor() {
    
    companion object {
        val shared = TestEngine()
    }
    
    /**
     * Run all tests and return results
     */
    suspend fun runAllTests(context: Context): List<TestResult> = withContext(Dispatchers.IO) {
        val results = mutableListOf<TestResult>()
        
        // Core Library Tests
        results.add(runTest("Library Version") { testLibraryVersion() })
        results.add(runTest("Error Handling") { testErrorHandling() })
        results.add(runTest("Read Test Image") { testReadImage(context) })
        results.add(runTest("Stream API") { testStreamAPI(context) })
        results.add(runTest("Builder API") { testBuilderAPI(context) })
        results.add(runTest("Builder No-Embed API") { testBuilderNoEmbed() })
        results.add(runTest("Read Ingredient") { testReadIngredient(context) })
        results.add(runTest("Invalid File Handling") { testInvalidFileHandling(context) })
        results.add(runTest("Resource Reading") { testResourceReading(context) })
        results.add(runTest("Builder Remote URL") { testBuilderRemoteURL() })
        results.add(runTest("Builder Add Resource") { testBuilderAddResource() })
        results.add(runTest("Builder Add Ingredient") { testBuilderAddIngredient(context) })
        results.add(runTest("Builder from Archive") { testBuilderFromArchive() })
        results.add(runTest("Reader with Manifest Data") { testReaderWithManifestData(context) })
        results.add(runTest("Signer with Callback") { testSignerWithCallback(context) })
        results.add(runTest("File Operations with Data Dir") { testFileOperationsWithDataDir(context) })
        results.add(runTest("Write-Only Streams") { testWriteOnlyStreams() })
        results.add(runTest("Custom Stream Callbacks") { testCustomStreamCallbacks() })
        results.add(runTest("Stream File Options") { testStreamFileOptions(context) })
        
        // Signing Tests
        results.add(runTest("Web Service Real Signing & Verification") { testWebServiceSignerCreation(context) })
        results.add(runTest("Keystore Signer Creation") { testKeystoreSignerCreation() })
        results.add(runTest("Signing Algorithm Tests") { testSigningAlgorithmTests(context) })
        results.add(runTest("Signer Reserve Size") { testSignerReserveSize(context) })
        results.add(runTest("Reader Resource Error Handling") { testReaderResourceErrorHandling(context) })
        results.add(runTest("Error Enum Coverage") { testErrorEnumCoverage() })
        
        // Hardware Security Tests (StrongBox/TEE equivalent to iOS Secure Enclave)
        results.add(runTest("Hardware Security Capabilities") { testHardwareSecurityCapabilities(context) })
        results.add(runTest("Hardware Key Generation") { testHardwareKeyGeneration() })
        results.add(runTest("Hardware-Backed Signer Creation") { testHardwareBackedSignerCreation(context) })
        results.add(runTest("Hardware Key Attestation") { testHardwareKeyAttestation() })
        results.add(runTest("StrongBox vs TEE Detection") { testStrongBoxTEEDetection(context) })
        results.add(runTest("Hardware Key Lifecycle") { testHardwareKeyLifecycle() })
        
        results
    }
    
    // MARK: - Individual Test Methods (Public Wrappers)
    
    suspend fun runLibraryVersionTest(): TestResult = runTest("Library Version") { testLibraryVersion() }
    suspend fun runErrorHandlingTest(): TestResult = runTest("Error Handling") { testErrorHandling() }
    suspend fun runReadImageTest(context: Context): TestResult = runTest("Read Test Image") { testReadImage(context) }
    suspend fun runStreamAPITest(context: Context): TestResult = runTest("Stream API") { testStreamAPI(context) }
    suspend fun runBuilderAPITest(context: Context): TestResult = runTest("Builder API") { testBuilderAPI(context) }
    suspend fun runBuilderNoEmbedTest(): TestResult = runTest("Builder No-Embed API") { testBuilderNoEmbed() }
    suspend fun runReadIngredientTest(context: Context): TestResult = runTest("Read Ingredient") { testReadIngredient(context) }

    private suspend fun runTest(name: String, test: suspend () -> TestResult): TestResult {
        return try {
            test()
        } catch (e: Exception) {
            TestResult(
                name = name,
                success = false,
                message = "✗ Test failed with error: ${e.message}",
                details = e.toString()
            )
        }
    }
    
    // MARK: - Individual Tests
    
    private fun testLibraryVersion(): TestResult {
        val testSteps = mutableListOf<String>()
        
        val version = C2PA.version()
        val success = version.isNotEmpty()
        
        if (success) {
            testSteps.add("✓ C2PA library version retrieved: $version")
        } else {
            testSteps.add("✗ Failed to retrieve C2PA library version")
        }
        
        return TestResult(
            name = "Library Version",
            success = success,
            message = testSteps.joinToString("\n"),
            details = "Library version: $version"
        )
    }
    
    private suspend fun testErrorHandling(): TestResult {
        val steps = mutableListOf<String>()
        
        return try {
            C2PA.readFile("/non/existent/file.jpg")
            steps.add("✗ Should have thrown an error for non-existent file")
            TestResult(
                name = "Error Handling",
                success = false,
                message = steps.joinToString("\n"),
                details = null
            )
        } catch (error: C2PAError) {
            steps.add("✓ Successfully caught C2PAError as expected")
            
            when (error) {
                is C2PAError.Api -> {
                    val containsExpectedError = error.message.contains("No such file or directory") ||
                            error.message.contains("file") || error.message.contains("exist")
                    if (containsExpectedError) {
                        steps.add("✓ Caught .Api error with expected file-related message")
                        steps.add("✓ Error message: ${error.message}")
                    } else {
                        steps.add("✗ Got .Api error but message doesn't contain expected text")
                        steps.add("✗ Actual message: ${error.message}")
                    }
                    
                    TestResult(
                        name = "Error Handling",
                        success = containsExpectedError,
                        message = steps.joinToString("\n"),
                        details = null
                    )
                }
                else -> {
                    steps.add("✗ Got unexpected error type: $error")
                    TestResult(
                        name = "Error Handling",
                        success = false,
                        message = steps.joinToString("\n"),
                        details = null
                    )
                }
            }
        } catch (e: Exception) {
            steps.add("✗ Got unexpected exception type instead of C2PAError: $e")
            TestResult(
                name = "Error Handling",
                success = false,
                message = steps.joinToString("\n"),
                details = e.toString()
            )
        }
    }
    
    private suspend fun testReadImage(): TestResult {
        val steps = mutableListOf<String>()
        
        val testImageFile = copyResourceToFile(R.raw.adobe_20220124_ci, "test_adobe.jpg")
        return try {
            steps.add("✓ Found test image 'adobe-20220124-CI.jpg' in resources")
            
            val manifestJSON = C2PA.readFile(testImageFile.absolutePath)
            steps.add("✓ Successfully read C2PA data from image")
            
            if (manifestJSON.isEmpty()) {
                steps.add("✗ Manifest JSON is empty")
                return TestResult(
                    name = "Read Test Image",
                    success = false,
                    message = steps.joinToString("\n"),
                    details = null
                )
            }
            steps.add("✓ Manifest JSON is not empty (${manifestJSON.length} characters)")
            
            val jsonObject = try {
                JSONObject(manifestJSON)
            } catch (e: Exception) {
                steps.add("✗ Could not parse manifest as JSON")
                return TestResult(
                    name = "Read Test Image",
                    success = false,
                    message = steps.joinToString("\n"),
                    details = null
                )
            }
            steps.add("✓ Successfully parsed manifest as JSON")
            
            var hasClaimGenerator = false
            
            if (jsonObject.has("manifests")) {
                val manifests = jsonObject.getJSONObject("manifests")
                steps.add("✓ Found 'manifests' object with ${manifests.length()} manifest(s)")
                val keys = manifests.keys()
                while (keys.hasNext() && !hasClaimGenerator) {
                    val key = keys.next()
                    val manifest = manifests.getJSONObject(key)
                    if (manifest.has("claim_generator")) {
                        hasClaimGenerator = true
                        val claimGen = manifest.getString("claim_generator")
                        steps.add("✓ Found claim_generator: '$claimGen'")
                    }
                }
                if (!hasClaimGenerator) {
                    steps.add("✗ No claim_generator found in any manifest")
                }
            } else if (jsonObject.has("claim_generator")) {
                hasClaimGenerator = true
                val claimGen = jsonObject.getString("claim_generator")
                steps.add("✓ Found top-level claim_generator: '$claimGen'")
            } else {
                steps.add("✗ No 'manifests' object or top-level claim_generator found")
            }
            
            if (hasClaimGenerator) {
                steps.add("✓ Successfully read and validated manifest with claim_generator")
            } else {
                steps.add("✗ Manifest lacks claim_generator field")
            }
            
            TestResult(
                name = "Read Test Image",
                success = hasClaimGenerator,
                message = steps.joinToString("\n"),
                details = null
            )
        } catch (e: Exception) {
            steps.add("✗ Failed to read manifest: ${e.message}")
            TestResult(
                name = "Read Test Image",
                success = false,
                message = steps.joinToString("\n"),
                details = null
            )
        } finally {
            testImageFile.delete()
        }
    }
    
    private suspend fun testStreamAPI(): TestResult {
        val steps = mutableListOf<String>()
        
        return try {
            steps.add("✓ Found test image 'adobe-20220124-CI.jpg' in resources")
            
            val imageData = getResourceAsBytes(R.raw.adobe_20220124_ci)
            steps.add("✓ Loaded image data (${imageData.size} bytes)")
            
            val stream = MemoryC2PAStream(imageData)
            steps.add("✓ Created Stream from data successfully")
            
            val reader = C2PAReader.fromStream("image/jpeg", stream)
            steps.add("✓ Created Reader from stream successfully")
            
            val manifestJSON = reader.json()
            steps.add("✓ Extracted JSON manifest (${manifestJSON.length} characters)")
            
            steps.add("✓ Successfully used Stream and Reader APIs")
            
            reader.close()
            stream.close()
            
            TestResult(
                name = "Stream API",
                success = true,
                message = steps.joinToString("\n"),
                details = null
            )
        } catch (e: Exception) {
            steps.add("✗ Failed to use Stream API: ${e.message}")
            TestResult(
                name = "Stream API",
                success = false,
                message = steps.joinToString("\n"),
                details = null
            )
        }
    }
    
    private suspend fun testBuilderAPI(): TestResult {
        val steps = mutableListOf<String>()
        
        return try {
            steps.add("✓ Found test image 'pexels-asadphoto-457882.jpg' in resources")
            steps.add("✓ Found signing certificates (es256_certs.pem and es256_private.key)")
            
            val imageData = getResourceAsBytes(R.raw.pexels_asadphoto_457882)
            val originalSize = imageData.size
            steps.add("✓ Loaded image data ($originalSize bytes)")
            
            // Check if original has C2PA data
            val tempFile = createTempFile("test", ".jpg")
            tempFile.writeBytes(imageData)
            val originalHasC2PA = try {
                C2PA.readFile(tempFile.absolutePath)
                true
            } catch (e: Exception) {
                false
            }
            tempFile.delete()
            steps.add("✓ Checked original image C2PA status: ${if (originalHasC2PA) "has C2PA data" else "no C2PA data"}")
            
            val certsPEM = getResourceAsString(R.raw.es256_certs)
            val privateKeyPEM = getResourceAsString(R.raw.es256_private)
            steps.add("✓ Loaded signing certificates and private key")
            
            val manifestJSON = """
            {
                "claim_generator": "C2PATestApp/1.0",
                "title": "Test Image with Embedded C2PA",
                "format": "image/jpeg",
                "assertions": [
                    {
                        "label": "c2pa.actions",
                        "data": {
                            "actions": [
                                {
                                    "action": "c2pa.created",
                                    "softwareAgent": "C2PATestApp"
                                }
                            ]
                        }
                    }
                ]
            }
            """.trimIndent()
            steps.add("✓ Created manifest JSON with C2PA actions")
            
            val builder = C2PABuilder.fromJson(manifestJSON)
            steps.add("✓ Created Builder from manifest JSON")
            
            val signer = C2PASigner.fromPEM(
                certsPEM,
                privateKeyPEM,
                SigningAlgorithm.ES256
            )
            steps.add("✓ Created Signer from PEM certificates")
            
            val sourceStream = MemoryC2PAStream(imageData)
            val destStream = MemoryC2PAStream()
            
            val manifestBytes = builder.sign("image/jpeg", sourceStream, destStream, signer)
            val signedData = destStream.getData()
            val signedSize = signedData.size
            
            steps.add("✓ Signed image successfully")
            steps.add("✓ Original size: $originalSize bytes")
            steps.add("✓ Signed size: $signedSize bytes")
            steps.add("✓ Size increase: ${signedSize - originalSize} bytes")
            
            // Verify the signed image has C2PA data
            val verifyStream = MemoryC2PAStream(signedData)
            val verifyReader = C2PAReader.fromStream("image/jpeg", verifyStream)
            val verifyJSON = verifyReader.json()
            
            steps.add("✓ Successfully verified signed image contains valid C2PA data")
            
            // Cleanup
            verifyReader.close()
            verifyStream.close()
            builder.close()
            signer.close()
            sourceStream.close()
            destStream.close()
            
            TestResult(
                name = "Builder API",
                success = signedSize > originalSize,
                message = steps.joinToString("\n"),
                details = "Manifest size: ${manifestBytes.size} bytes"
            )
        } catch (e: Exception) {
            steps.add("✗ Failed to use Builder API: ${e.message}")
            TestResult(
                name = "Builder API",
                success = false,
                message = steps.joinToString("\n"),
                details = e.toString()
            )
        }
    }
    
    private suspend fun testBuilderNoEmbed(): TestResult {
        val steps = mutableListOf<String>()
        
        return try {
            val manifestJSON = """
            {
                "claim_generator": "test_app/1.0",
                "assertions": [{"label": "c2pa.test", "data": {"test": true}}]
            }
            """.trimIndent()
            
            val builder = C2PABuilder.fromJson(manifestJSON)
            steps.add("✓ Created Builder from manifest JSON")
            
            builder.setNoEmbed()
            steps.add("✓ Set no-embed flag")
            
            val archiveStream = MemoryC2PAStream()
            builder.writeArchive(archiveStream)
            steps.add("✓ Wrote archive to stream")
            
            val archiveData = archiveStream.getData()
            val success = archiveData.isNotEmpty()
            
            steps.add(if (success) "✓ Archive created successfully" else "✗ Archive creation failed")
            steps.add("Archive size: ${archiveData.size} bytes")
            
            // Cleanup
            builder.close()
            archiveStream.close()
            
            TestResult(
                name = "Builder No-Embed API",
                success = success,
                message = steps.joinToString("\n"),
                details = "Archive size: ${archiveData.size}"
            )
        } catch (e: Exception) {
            steps.add("✗ Failed: ${e.message}")
            TestResult(
                name = "Builder No-Embed API",
                success = false,
                message = steps.joinToString("\n"),
                details = e.toString()
            )
        }
    }
    
